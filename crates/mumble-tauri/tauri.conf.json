{
  "productName": "Fancy Mumble",
  "version": "0.2.15",
  "identifier": "com.fancymumble.app",
  "build": {
    "frontendDist": "./ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "./ui" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "./ui" }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Fancy Mumble",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCODZEMTk5QTVCRDM4MzEKUldReE9MMmxtZEdHZS90QmRQbGZZMHZqL01oeUhDekx5SUMwY08yc1N6aC84RE1LSVR6aTRJRFYK",
      "endpoints": [
        "https://github.com/Fancy-Mumble/FancyMumbleNext/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
